# ═══════════════════════════════════════════════════════════════════════════════
# Confidence-Governed AI Ticket Resolution System — .gitignore
# ═══════════════════════════════════════════════════════════════════════════════

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
build/
.eggs/

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── Environment variables ─────────────────────────────────────────────────────
# NEVER commit real .env files — use .env.example as template
.env
.env.local
.env.*.local
backend/.env
frontend-react/.env
frontend-react/.env.local

# ── Database ──────────────────────────────────────────────────────────────────
*.sqlite3
*.db
test.db

# ── FAISS persisted index (generated at runtime, not source code) ─────────────
backend/data/faiss.index
backend/data/faiss_meta.json
*.faiss
*.index

# ── ML model weights (large binary files — regenerate with train_classifier.py)
*.bin
*.pt
*.onnx
*.safetensors
backend/models/ticket_classifier/pytorch_model.bin
backend/models/ticket_classifier/model.safetensors
backend/models/ticket_classifier/optimizer.pt
backend/models/ticket_classifier/checkpoint-*/
backend/models/ticket_classifier/runs/
# Keep metadata files — they document the model without storing weights
!backend/models/ticket_classifier/training_meta.json
!backend/models/ticket_classifier/config.json
!backend/models/ticket_classifier/tokenizer*.json
!backend/models/ticket_classifier/vocab.txt
!backend/models/ticket_classifier/special_tokens_map.json
!backend/models/label_map.json

# ── HuggingFace / Whisper model cache (downloaded automatically) ──────────────
.cache/
backend/.cache/
backend/venv/Lib/site-packages/~crypt/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/
*.log.*

# ── OS generated ──────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── IDE / Editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml
.tox/

# ── Node / React / Vite ───────────────────────────────────────────────────────
node_modules/
frontend-react/node_modules/
frontend-react/dist/
frontend-react/.vite/
.next/
out/

# ── Docker ────────────────────────────────────────────────────────────────────
docker-compose.override.yml
.docker/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Misc ──────────────────────────────────────────────────────────────────────
*.tmp
*.temp
*.bak
*.orig
edo.txt

# ── Uploaded files (runtime generated) ───────────────────────────────────────
backend/data/uploads/

# ── Audio temp files ──────────────────────────────────────────────────────────
*.webm
*.wav
*.mp3
*.ogg
*.m4a
